#!/bin/bash
# Pre-push hook: run audit scripts before allowing push.
# Block push if any high-severity issues found.

set -e

cd "$(git rev-parse --show-toplevel)"

if [ -f scripts/link_audit.py ]; then
    echo "running link audit..."
    if ! python3 scripts/link_audit.py > /tmp/link_audit.log 2>&1; then
        echo "LINK AUDIT FAILED. push blocked."
        echo "see /tmp/link_audit.log for details."
        tail -10 /tmp/link_audit.log
        exit 1
    fi
    echo "  link audit OK"
fi

if [ -f scripts/voice_audit.py ]; then
    echo "running voice audit..."
    if ! python3 scripts/voice_audit.py > /tmp/voice_audit.log 2>&1; then
        echo "VOICE AUDIT FAILED (high-severity issues). push blocked."
        echo "see /tmp/voice_audit.log for details."
        tail -10 /tmp/voice_audit.log
        exit 1
    fi
    echo "  voice audit OK"
fi

echo "all audits pass. proceeding with push."
exit 0
